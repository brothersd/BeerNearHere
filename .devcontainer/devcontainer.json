// .devcontainer/devcontainer.json
{
    "name": "Beer Near Here Backend",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "web",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.black-formatter",
                "batisteo.vscode-django",
                "mtxr.sqltools",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "remoteEnv": {
        "PYTHONPATH": "/app"
    }
}